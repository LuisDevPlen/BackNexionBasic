PORT=3000
# Postgres local (Docker ou instalado):
# DATABASE_URL=postgresql://postgres:SENHA@localhost:5432/NexionDatabase
#
# Neon — copie a connection string do dashboard (Pooling ou Direct), com sslmode=require:
# DATABASE_URL=postgresql://USER:SENHA@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
#
DATABASE_URL=postgresql://postgres:9191@localhost:5432/NexionDatabase
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio
# Origem do front (sem barra no fim). Várias: separar por vírgula
# CORS_ORIGIN=http://localhost:4200
# CORS_ORIGIN=https://front-nexion-basic.vercel.app,http://localhost:4200
CORS_ORIGIN=http://localhost:4200
# Opcional: primeiro admin (só é criado se não existir)
ADMIN_SEED_EMAIL=admin@nexion.local
ADMIN_SEED_PASSWORD=admin123
#
# E-mail ao concluir pedido (opcional). Sem MAIL_TO o envio é ignorado.
# Ex.: Gmail com “senha de app”; ou SMTP do seu provedor.
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=seu@gmail.com
# MAIL_PASS=senha_de_app
# MAIL_FROM=Nexion <seu@gmail.com>
# MAIL_TO=loja@exemplo.com
# Vários destinatários: MAIL_TO=a@x.com,b@x.com
